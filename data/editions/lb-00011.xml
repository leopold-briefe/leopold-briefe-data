	<text>
		<body>
			<div>
				<div type="page"><pb facs="#facs_1" n="1"/>
				<p facs="#facs_1_tr_1">
					<lb facs="#facs_1_tr_1_tl_1" n="N001"/>&amp; 14th August 1678
					<lb facs="#facs_1_tr_1_tl_2" n="N002"/>Lieber Wrate!
					<lb facs="#facs_1_tr_1_tl_3" n="N003"/>Aus Euern Schreiben von 29 ten passati habe ich gesehen
					<lb facs="#facs_1_tr_1_tl_4" n="N004"/>die freüde so ihr habt, über den nur von Gott
					<lb facs="#facs_1_tr_1_tl_5" n="N005"/>den Allmächtigen verliehenen Sohn, und habe
					<lb facs="#facs_1_tr_1_tl_6" n="N006"/>zur bezeigung meines Vergnügens das ich
					<lb facs="#facs_1_tr_1_tl_7" n="N007"/>ob Euerer Glückwünschung trage, daß gnädigste
					<lb facs="#facs_1_tr_1_tl_8" n="N008"/>Dancksagung hiemit verrichten wollen, und
					<lb facs="#facs_1_tr_1_tl_9" n="N009"/>wollet gesichert sein, daß ich allezeit zu Euch
					<lb facs="#facs_1_tr_1_tl_10" n="N010"/>alle gewogenheit habe, die ihr immer vernehmen
					<lb facs="#facs_1_tr_1_tl_11" n="N011"/>wirdet übrigens sehr ich, daß die
					<lb facs="#facs_1_tr_1_tl_12" n="N012"/>den 2ten April des
					<lb facs="#facs_1_tr_1_tl_13" n="N013"/>nicht abnehmen, sondern vergrößert werden
					<lb facs="#facs_1_tr_1_tl_14" n="N014"/>So mehr wollet ihr, vor anderen allen müssen
					<lb facs="#facs_1_tr_1_tl_15" n="N015"/>Ein Mittel suchen dis zu verhindern
					<lb facs="#facs_1_tr_1_tl_16" n="N016"/>Wir geblieben Eüch übrigens mit Kögl. Hulden
					<lb facs="#facs_1_tr_1_tl_17" n="N017"/>Wien d. 14 Aug
					<lb facs="#facs_1_tr_1_tl_18" n="N018"/>und Gnaden wohl gewogen
					<lb facs="#facs_1_tr_1_tl_19" n="N019"/>1678.
					<lb facs="#facs_1_tr_1_tl_20" n="N020"/>Leopold
				</p>
				</div><div type="page"><pb facs="#facs_2" n="2"/>
			</div></div>
		</body>
	</text>
