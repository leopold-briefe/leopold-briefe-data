	<text>
		<body>
			<div>
				<div type="page"><pb facs="#facs_1" n="1"/>
				<p facs="#facs_1_tr_1">
					<lb facs="#facs_1_tr_1_tl_1" n="N001"/>Lieber Lamberg. Auß euren relationen de datis 15. et 22. Maij
					<lb facs="#facs_1_tr_1_tl_2" n="N002"/>hab ich mitt grossen freüden der aldortigen <choice><expan/><abbr>Majestäten</abbr></choice> v<corr>n</corr>d <choice><expan/><abbr>Durchlauchten</abbr></choice>
					<lb facs="#facs_1_tr_1_tl_3" n="N003"/>guette gesündheitt vernommen, wie auch, daß die g<corr>r</corr>avidanza
					<lb facs="#facs_1_tr_1_tl_4" n="N004"/>der konigin noch glükhlich Gott sey lob continuiren.
					<lb facs="#facs_1_tr_1_tl_5" n="N005"/>Alhie haben wir der w<corr>a</corr>l dermal ein rechten anfang
					<lb facs="#facs_1_tr_1_tl_6" n="N006"/>gemacht, indeme ein ganz <choice><expan>khurcollegium</expan><abbr>khur.</abbr></choice>, worunder ich auch in persona
					<lb facs="#facs_1_tr_1_tl_7" n="N007"/>gewesen, <sic rend="error" n="die">di</sic> alhiesige statt in die gewonhlichen <del rend="strikethrough">pfilht</del> pflicht<note>Frankfurter Stadtrat wurde am 22. Juni 1658 vereidigt, Gotthard 491.</note>
					<lb facs="#facs_1_tr_1_tl_8" n="N008"/>vnd iuramentum securitatis praestandae<note>Frankfurter Stadtrat wurde am 22. Juni 1658 vereidigt, Gotthard 491.</note> genommen haben, hoffe es
					<lb facs="#facs_1_tr_1_tl_9" n="N009"/>werde, a<corr>ll</corr>es baldt zu ein ende kho<choice><expan/><abbr>mm</abbr></choice>en. <seg type="cypher">fa 4</seg> <seg type="code" n="Der Kurfürst von Trier,">AL</seg> <seg type="cypher">6 2 go</seg> <seg type="code" n="der Kurfürst von Bayern,">AM</seg> <seg type="cypher">8</seg>
					<lb facs="#facs_1_tr_1_tl_10" n="N010"/><seg type="cypher">Kem</seg> <seg type="code" n="der Kurfürst von Sachsen">AN</seg> <seg type="cypher" n="vnd">9 n 2 d</seg> <seg type="code" n="der Kurfürst von Brandenburg">AO</seg> <seg type="cypher" n="halten noch fest mitt vns,">h 1 l 4 t <corr>3</corr> n gli n 7 c 6 h f 3 s 4 t mo m 5 t 8 t 9 n s</seg> <seg type="code" n="der Kurfürst von Mainz,">AI</seg> <seg type="cypher">ba</seg>
					<lb facs="#facs_1_tr_1_tl_11" n="N011"/><seg type="code" n="der Kurfürst von Köln,">AK</seg> <seg type="cypher" n="et">3 t</seg> <seg type="code" n="der Kurfürst von der Pfalz">AP</seg> <seg type="cypher" n="sein clientes"><unclear>f</unclear>om s 3 5 n lim c 2 l 5 3 n 4 t lo 3 s</seg> <seg type="code" n="des Königs von Frankreich">AE</seg> <seg type="cypher" n="vnd thuen alles,">9 n 4 d t h 9 3 n pe 1 l 4 l 3 s</seg>
					<lb facs="#facs_1_tr_1_tl_12" n="N012"/><seg type="cypher" n="was ihnen beliebt">w 1 s ni 5 h n 3 4 6 n <corr>b</corr> 3 l <corr>5</corr> 6 3 b t</seg>. In vbrigen <seg type="cypher" n="wierdt">w 5 3 r d 4 2 t</seg> <seg type="code" n="Portia">AS</seg> <seg type="cypher">6 8 fa</seg>
					<lb facs="#facs_1_tr_1_tl_13" n="N013"/><seg type="cypher" n="dem">4 d 3 m</seg> <seg type="code" n="Lamberg">AX</seg> <seg type="cypher" n="alles ausfurlicher schreiben">1 l 4 l 3 s fo 1 9 5 f 4 9 r l 5 c h 3 r gli s c 4 h r 5 3 6 b<corr>a</corr>m b 3 n 6 8 po 4 2</seg>.
					<lb facs="#facs_1_l_1" n="N014"/>Vnd ich bin allezeitt eur <choice><expan/><abbr>gnädigster</abbr></choice> konig vnd herr
					<lb facs="#facs_1_tr_1_tl_17" n="N015"/>Leopoldt
					<lb facs="#facs_1_l" n="N016"/><choice><expan>Frankfürdt</expan><abbr>FFürdt</abbr></choice>, <del rend="strikethrough">den</del>
					<lb facs="#facs_1_tr_1_tl_15" n="N017"/>den 22. Maij
					<lb facs="#facs_1_tr_1_tl_16" n="N018"/>1658
				</p>
