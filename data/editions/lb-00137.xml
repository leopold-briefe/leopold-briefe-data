	<text>
		<body>
			<div>
				<div type="page"><pb facs="#facs_1" n="1"/>
				<p facs="#facs_1_tr_1">
					<lb facs="#facs_1_tr_1_tl_2" n="N001"/>Lieber Lamberg. Eure beede schreiben von 29. Maij
					<lb facs="#facs_1_tr_1_tl_3" n="N002"/>vnd 5. Juni seindt mir zu recht eingelifferdt worden.
					<lb facs="#facs_1_tr_1_tl_4" n="N003"/>Daß erste hatt mich ein wenig erschrecht, weiln ich vernommen,
					<lb facs="#facs_1_tr_1_tl_5" n="N004"/>daß der prinz etwaß <sic rend="error" n="vbl">vbr</sic> auf gewesen, daß andere aber
					<lb facs="#facs_1_tr_1_tl_6" n="N005"/>hatt mich wider <del rend="strikethrough"><unclear>ger</unclear></del> getrost, weil ich siche, daß khein gefar
					<lb facs="#facs_1_tr_1_tl_7" n="N006"/>mer ist. Sed quid nostris hic reb<choice><expan/><abbr>us</abbr></choice> scrib<corr>e</corr>re debeam,
					<lb facs="#facs_1_tr_1_tl_8" n="N007"/>vere nescio? Dann es gehet so vnbestendig vnd langsamb
					<lb facs="#facs_1_tr_1_tl_9" n="N008"/>zue, daß es vnmüeglich, in so wenig zeilen außzusprechen.
					<lb facs="#facs_1_tr_1_tl_10" n="N009"/><seg type="cypher" n="In">6 5 n <unclear>g</unclear>lo</seg> <seg type="code" n="Belgio">BF</seg> <seg type="cypher" n="gehet es alles vber vnt vber, in">g 3 h 4 3 t 3 s 1 l 2 l 3 s fa 9 b 3 r 9 n 8 t 9 b <corr>3</corr> r tom 6 5 n</seg> <seg type="cypher" n="Italia">BG</seg>
					<lb facs="#facs_1_tr_1_tl_11" n="N010"/><seg type="cypher" n="gehet es auch nitt besser">g 3 mo h 4 3 t 3 8 s 1 9 c 4 h n i t 4 t lim b 3 s 3 s r<note>Irrtümlich chiffriert: besesr.</note></seg>. <seg type="cypher" n="In summa">Im 5 n s 9 m 6 m 1 go 3 s</seg>
					<lb facs="#facs_1_tr_1_tl_12" n="N011"/><seg type="cypher" n="sehet alles gar vbel alhie">s t 3 h 3 t 1 l l 3 <corr>s</corr> g 1 r lom 9 b 3 l gam 4 te 1 l h 5 3</seg>. <seg type="code" n="Der Kurfúrst von Mainz,">AJ</seg> <seg type="cypher">6</seg> <seg type="code" n="der Kurfúrst von Köln">AK</seg> <seg type="cypher" n="et">pa <corr>3</corr> t</seg> <seg type="code" n="der Kurfúrst von Pfalz">AP</seg>
					<lb facs="#facs_1_tr_1_tl_13" n="N012"/><seg type="cypher" n="thuen alles aufs vbliste, als sie kennen">t h 9 3 n ro 1 l 6 l 3 s 1 9 f s 9 b 4 l 5 s <unclear>r</unclear>i t 3 1 l s lim s 5 3 k 3 n n 4 6 3 n</seg>.
					<lb facs="#facs_1_tr_1_tl_14" n="N013"/><seg type="code" n="Der Kurfúrst von Trier,">AL</seg> <seg type="cypher">go</seg> <seg type="code" n="der Kurfúrst von Bayern">AM</seg> <seg type="cypher" n="und">8 2 9 n d</seg> <seg type="code" n="der Kurfúrst von Sachsen">AN</seg> zwar thuen <seg type="cypher" n="noch das">6 gli n 7 c 4 h d 1 s</seg>
					<lb facs="#facs_1_tr_1_tl_15" n="N014"/><seg type="cypher" n="ihrige, sunt autem timidi">5 h r 5 g 3 po s 9 n 4 t 1 9 t 3 m ra t 5 m 6 5 d 4 5</seg>. <seg type="code" n="Der Kurfúrst von Brandemburg">AO</seg> <seg type="cypher" n="ist gar">5 s t g 1 r ba</seg>
					<lb facs="#facs_1_tr_1_tl_16" n="N015"/><seg type="cypher" n="vnbestendig, uere res nostrae male se habent">9 n b 3 4 s li t 3 n 6 d 5 g 9 3 r 3 r <corr>3</corr> s go n 7 s 4 t r 1 3 m 1 <hi rend="superscript">4</hi> l <corr>3</corr> s 3 h 1 b 3 n 6 t</seg>
					<lb facs="#facs_1_tr_1_tl_17" n="N016"/><seg type="cypher">gam 64 82 lom</seg>. De caetero mi rimetto al conte di Portia
					<lb facs="#facs_1_tr_1_tl_18" n="N017"/>vnd verbleib alzeitt eur <choice><expan/><abbr>gnädigster</abbr></choice> konig vnd herr
					<lb facs="#facs_1_tr_1_tl_21" n="N018"/>Leopoldt
					<lb facs="#facs_1_tr_1_tl_19" n="N019"/><seg type="cypher" n="Frankfürdth">FFürdth</seg>, den 6 <del rend="strikethrough">Juli</del>
					<lb facs="#facs_1_tr_1_tl_20" n="N020"/>Julij 1658
					<lb facs="#facs_1_l_1" n="N021"/>P. S.
					<lb facs="#facs_1_tr_1_tl_25" n="N022"/>Oblit<choice><expan/><abbr>us</abbr></choice> quasi fueram, da<corr>ß</corr> ich gestern bey Saxen zu
					<lb facs="#facs_1_tr_1_tl_26" n="N023"/>gast gewesen, wie auch vorhero bey Trir vnd Meinz, vnd haben vbral
					<lb facs="#facs_1_tr_1_tl_27" n="N024"/>secundum morem gentis nostrae in gutter vertreulikheitt vnd fraterna
					<lb facs="#facs_1_tr_1_tl_28" n="N025"/>charitate ein jesuiter reischel<note>Jesuitenrausch = ein mäßiger, unsündlicher Rausch.</note> davon tragen <sic rend="error" n="muessen">muess</sic>. Beyligende
					<lb facs="#facs_1_l" n="N026"/>2 schreiben werden ihr schon wissen zu vbrliffern.
				</p>
